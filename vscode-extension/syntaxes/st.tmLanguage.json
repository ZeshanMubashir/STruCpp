{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Structured Text (IEC 61131-3)",
  "scopeName": "source.iec61131-st",
  "patterns": [
    { "include": "#comments" },
    { "include": "#pragmas" },
    { "include": "#strings" },
    { "include": "#datetime-literals" },
    { "include": "#typed-literals" },
    { "include": "#numeric-literals" },
    { "include": "#direct-addresses" },
    { "include": "#boolean-constants" },
    { "include": "#null-constant" },
    { "include": "#test-framework" },
    { "include": "#pou-declarations" },
    { "include": "#oop-keywords" },
    { "include": "#type-declarations" },
    { "include": "#variable-blocks" },
    { "include": "#configuration-keywords" },
    { "include": "#control-flow" },
    { "include": "#operators" },
    { "include": "#elementary-types" },
    { "include": "#reference-keywords" },
    { "include": "#memory-keywords" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.st",
          "match": "//.*$"
        },
        {
          "name": "comment.block.st",
          "begin": "\\(\\*",
          "end": "\\*\\)",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "pragmas": {
      "patterns": [
        {
          "name": "meta.pragma.external.st",
          "begin": "\\{external\\b",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "keyword.control.pragma.st" }
          },
          "endCaptures": {
            "0": { "name": "keyword.control.pragma.st" }
          },
          "contentName": "meta.embedded.block.cpp"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.st",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.st",
              "match": "\\$(?:\\$|'|[LNPRTlnprt]|[0-9A-Fa-f]{2})"
            },
            {
              "name": "constant.character.escape.st",
              "match": "''"
            }
          ]
        },
        {
          "name": "string.quoted.double.st",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.st",
              "match": "\\$(?:\\$|\"|[LNPRTlnprt]|[0-9A-Fa-f]{4})"
            }
          ]
        }
      ]
    },
    "datetime-literals": {
      "patterns": [
        {
          "name": "constant.other.datetime.st",
          "match": "(?i)(?:DT|DATE_AND_TIME)#[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?"
        },
        {
          "name": "constant.other.timeofday.st",
          "match": "(?i)(?:TOD|TIME_OF_DAY)#[0-9]{2}:[0-9]{2}(?::[0-9]{2}(?:\\.[0-9]+)?)?"
        },
        {
          "name": "constant.other.date.st",
          "match": "(?i)(?:D|DATE)#[0-9]{4}-[0-9]{2}-[0-9]{2}"
        },
        {
          "name": "constant.other.time.st",
          "match": "(?i)(?:T|TIME)#(?:[0-9_]+(?:\\.[0-9_]+)?(?:ms|us|ns|d|h|m|s))+"
        }
      ]
    },
    "typed-literals": {
      "patterns": [
        {
          "name": "constant.numeric.typed.st",
          "match": "(?i)(?:BYTE|WORD|DWORD|LWORD|SINT|INT|DINT|LINT|USINT|UINT|UDINT|ULINT|BOOL|REAL|LREAL)#(?:16#[0-9A-Fa-f_]+|8#[0-7_]+|2#[01_]+|[0-9][0-9_]*(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?)",
          "captures": {
            "0": { "name": "constant.numeric.typed.st" }
          }
        }
      ]
    },
    "numeric-literals": {
      "patterns": [
        {
          "name": "constant.numeric.hex.st",
          "match": "\\b16#[0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.octal.st",
          "match": "\\b8#[0-7_]+\\b"
        },
        {
          "name": "constant.numeric.binary.st",
          "match": "\\b2#[01_]+\\b"
        },
        {
          "name": "constant.numeric.float.st",
          "match": "\\b[0-9]+\\.[0-9]+(?:[eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.float.st",
          "match": "\\b[0-9]+[eE][+-]?[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.st",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "direct-addresses": {
      "patterns": [
        {
          "name": "variable.other.address.st",
          "match": "(?i)%[IQM][XBWDL]?[0-9]+(?:\\.[0-9]+)*"
        }
      ]
    },
    "boolean-constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.st",
          "match": "(?i)\\b(?:TRUE|FALSE)\\b"
        }
      ]
    },
    "null-constant": {
      "patterns": [
        {
          "name": "constant.language.null.st",
          "match": "(?i)\\bNULL\\b"
        }
      ]
    },
    "test-framework": {
      "patterns": [
        {
          "name": "keyword.control.test.st",
          "match": "(?i)\\b(?:TEST|END_TEST|SETUP|END_SETUP|TEARDOWN|END_TEARDOWN|ADVANCE_TIME)\\b"
        },
        {
          "name": "support.function.assert.st",
          "match": "(?i)\\b(?:ASSERT_EQ|ASSERT_NEQ|ASSERT_TRUE|ASSERT_FALSE|ASSERT_GT|ASSERT_LT|ASSERT_GE|ASSERT_LE|ASSERT_NEAR)\\b"
        },
        {
          "name": "support.function.mock.st",
          "match": "(?i)\\b(?:MOCK|MOCK_FUNCTION|MOCK_VERIFY_CALLED|MOCK_VERIFY_CALL_COUNT|RETURNS)\\b"
        }
      ]
    },
    "pou-declarations": {
      "patterns": [
        {
          "name": "keyword.declaration.pou.st",
          "match": "(?i)\\b(?:PROGRAM|END_PROGRAM|FUNCTION_BLOCK|END_FUNCTION_BLOCK|FUNCTION|END_FUNCTION)\\b"
        }
      ]
    },
    "oop-keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.oop.st",
          "match": "(?i)\\b(?:METHOD|END_METHOD|INTERFACE|END_INTERFACE|PROPERTY|END_PROPERTY|GET|END_GET|SET|END_SET)\\b"
        },
        {
          "name": "keyword.other.oop.st",
          "match": "(?i)\\b(?:EXTENDS|IMPLEMENTS|THIS|SUPER|ABSTRACT|FINAL|OVERRIDE)\\b"
        },
        {
          "name": "keyword.other.visibility.st",
          "match": "(?i)\\b(?:PUBLIC|PRIVATE|PROTECTED)\\b"
        }
      ]
    },
    "type-declarations": {
      "patterns": [
        {
          "name": "keyword.declaration.type.st",
          "match": "(?i)\\b(?:TYPE|END_TYPE|STRUCT|END_STRUCT|ARRAY)\\b"
        }
      ]
    },
    "variable-blocks": {
      "patterns": [
        {
          "name": "keyword.declaration.variable.st",
          "match": "(?i)\\b(?:VAR_INPUT|VAR_OUTPUT|VAR_IN_OUT|VAR_EXTERNAL|VAR_GLOBAL|VAR_TEMP|VAR_INST|VAR|END_VAR)\\b"
        },
        {
          "name": "keyword.modifier.variable.st",
          "match": "(?i)\\b(?:CONSTANT|RETAIN|AT)\\b"
        }
      ]
    },
    "configuration-keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.config.st",
          "match": "(?i)\\b(?:CONFIGURATION|END_CONFIGURATION|RESOURCE|END_RESOURCE|TASK|WITH|ON)\\b"
        }
      ]
    },
    "control-flow": {
      "patterns": [
        {
          "name": "keyword.control.st",
          "match": "(?i)\\b(?:IF|THEN|ELSIF|ELSE|END_IF|CASE|END_CASE|FOR|TO|BY|DO|END_FOR|WHILE|END_WHILE|REPEAT|UNTIL|END_REPEAT|EXIT|RETURN|OF)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.st",
          "match": "(?i)\\b(?:AND|OR|XOR|NOT|MOD)\\b"
        },
        {
          "name": "keyword.operator.assignment.ref.st",
          "match": "(?i)\\bREF=\\b"
        },
        {
          "name": "keyword.operator.assignment.st",
          "match": ":="
        },
        {
          "name": "keyword.operator.output.st",
          "match": "=>"
        },
        {
          "name": "keyword.operator.comparison.st",
          "match": "<>|<=|>=|<|>|="
        },
        {
          "name": "keyword.operator.arithmetic.st",
          "match": "\\*\\*|\\+|-|\\*|/"
        },
        {
          "name": "keyword.operator.pointer.st",
          "match": "\\^|&"
        }
      ]
    },
    "elementary-types": {
      "patterns": [
        {
          "name": "support.type.elementary.st",
          "match": "(?i)\\b(?:BOOL|BYTE|WORD|DWORD|LWORD|SINT|INT|DINT|LINT|USINT|UINT|UDINT|ULINT|REAL|LREAL|STRING|WSTRING|TIME|DATE|TIME_OF_DAY|TOD|DATE_AND_TIME|DT)\\b"
        }
      ]
    },
    "reference-keywords": {
      "patterns": [
        {
          "name": "keyword.other.reference.st",
          "match": "(?i)\\b(?:REFERENCE_TO|REF_TO|REF|DREF|POINTER)\\b"
        }
      ]
    },
    "memory-keywords": {
      "patterns": [
        {
          "name": "keyword.other.memory.st",
          "match": "(?i)\\b(?:__NEW|__DELETE)\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.st",
          "match": "[;,]"
        },
        {
          "name": "punctuation.range.st",
          "match": "\\.\\."
        },
        {
          "name": "punctuation.accessor.st",
          "match": "\\."
        },
        {
          "name": "punctuation.definition.colon.st",
          "match": ":"
        },
        {
          "name": "punctuation.section.parens.begin.st",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.st",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.st",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.st",
          "match": "\\]"
        }
      ]
    }
  }
}
