{
  "name": "strucpp-vscode",
  "displayName": "STruC++ — Structured Text IDE",
  "description": "IEC 61131-3 Structured Text language support powered by the STruC++ compiler",
  "version": "0.1.0",
  "publisher": "autonomy-logic",
  "license": "GPL-3.0-or-later",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/client.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "structured-text",
        "aliases": [
          "Structured Text",
          "IEC 61131-3 ST",
          "ST"
        ],
        "extensions": [
          ".st",
          ".iecst",
          ".ST"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "structured-text",
        "scopeName": "source.iec61131-st",
        "path": "./syntaxes/st.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "strucpp.compile",
        "title": "STruC++: Compile Current File to C++",
        "enablement": "editorLangId == structured-text"
      },
      {
        "command": "strucpp.compileWorkspace",
        "title": "STruC++: Compile Workspace to C++",
        "enablement": "workspaceFolderCount > 0"
      },
      {
        "command": "strucpp.build",
        "title": "STruC++: Build Executable (REPL)",
        "enablement": "editorLangId == structured-text"
      },
      {
        "command": "strucpp.buildAndRun",
        "title": "STruC++: Build and Run REPL",
        "icon": "$(play)",
        "enablement": "editorLangId == structured-text"
      },
      {
        "command": "strucpp.buildAndRunCyclic",
        "title": "STruC++: Build and Run (Cyclic)",
        "icon": "$(debug-alt-small)",
        "enablement": "editorLangId == structured-text"
      },
      {
        "command": "strucpp.debugBuild",
        "title": "STruC++: Debug Program",
        "icon": "$(debug-alt-small)",
        "enablement": "editorLangId == structured-text"
      },
      {
        "command": "strucpp.compileLib",
        "title": "STruC++: Compile Library (.stlib)",
        "icon": "$(package)",
        "enablement": "editorLangId == structured-text"
      },
      {
        "command": "strucpp.refreshLibraries",
        "title": "STruC++: Refresh Libraries",
        "icon": "$(refresh)"
      },
      {
        "command": "strucpp.runTests",
        "title": "STruC++: Run Tests",
        "icon": "$(testing-run-icon)",
        "enablement": "editorLangId == structured-text"
      },
      {
        "command": "strucpp.forceVariable",
        "title": "STruC++: Force Variable",
        "icon": "$(lock)",
        "enablement": "debugState == stopped"
      },
      {
        "command": "strucpp.unforceVariable",
        "title": "STruC++: Unforce Variable",
        "icon": "$(unlock)",
        "enablement": "debugState == stopped"
      },
      {
        "command": "strucpp.unforceAll",
        "title": "STruC++: Unforce All Variables",
        "icon": "$(unlock)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "strucpp.libraryExplorer",
          "name": "STruC++ Libraries",
          "when": "workspaceFolderCount > 0"
        }
      ],
      "debug": [
        {
          "id": "strucpp.forcedVariables",
          "name": "Forced Variables",
          "when": "inDebugMode"
        }
      ]
    },
    "menus": {
      "editor/title/run": [
        {
          "command": "strucpp.debugBuild",
          "group": "navigation@1",
          "when": "editorLangId == structured-text"
        },
        {
          "command": "strucpp.buildAndRun",
          "group": "navigation@2",
          "when": "editorLangId == structured-text"
        },
        {
          "command": "strucpp.compileLib",
          "group": "navigation@3",
          "when": "editorLangId == structured-text"
        }
      ],
      "debug/variables/context": [
        {
          "command": "strucpp.forceVariable",
          "when": "debugState == stopped",
          "group": "3_strucpp@1"
        },
        {
          "command": "strucpp.unforceVariable",
          "when": "debugState == stopped",
          "group": "3_strucpp@2"
        }
      ],
      "view/title": [
        {
          "command": "strucpp.refreshLibraries",
          "when": "view == strucpp.libraryExplorer",
          "group": "navigation"
        },
        {
          "command": "strucpp.unforceAll",
          "when": "view == strucpp.forcedVariables",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "strucpp.unforceVariable",
          "when": "view == strucpp.forcedVariables && viewItem == forcedVariable",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "STruC++",
      "properties": {
        "strucpp.libraryPaths": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Additional .stlib library search paths"
        },
        "strucpp.autoDiscoverLibraries": {
          "type": "boolean",
          "default": true,
          "description": "Auto-discover .stlib files anywhere in the workspace"
        },
        "strucpp.outputDirectory": {
          "type": "string",
          "default": "./generated",
          "description": "Output directory for generated C++ files (relative to workspace root)"
        },
        "strucpp.gppPath": {
          "type": "string",
          "default": "g++",
          "description": "Path to the g++ compiler"
        },
        "strucpp.ccPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the C compiler. Defaults to `cc` on macOS/Linux, `gcc` on Windows."
        },
        "strucpp.cxxFlags": {
          "type": "string",
          "default": "",
          "description": "Extra C++ compiler flags passed to g++"
        },
        "strucpp.globalConstants": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "default": {},
          "description": "Global constants passed to the compiler (-D NAME=VALUE)"
        },
        "strucpp.autoAnalyze": {
          "type": "boolean",
          "default": true,
          "description": "Automatically analyze files on change"
        },
        "strucpp.analyzeDelay": {
          "type": "number",
          "default": 400,
          "minimum": 100,
          "maximum": 5000,
          "description": "Debounce delay in milliseconds before re-analyzing after a change"
        },
        "strucpp.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format Structured Text files on save"
        }
      }
    },
    "breakpoints": [
      {
        "language": "structured-text"
      }
    ],
    "debuggers": [
      {
        "type": "strucpp",
        "label": "STruC++ Debug",
        "languages": ["structured-text"],
        "configurationAttributes": {
          "launch": {
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the debug binary (auto-filled by debug build)"
              },
              "args": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Arguments to pass to the program",
                "default": ["--cyclic"]
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the program"
              },
              "env": {
                "type": "object",
                "description": "Environment variables"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop at program entry point",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "strucpp",
            "request": "launch",
            "name": "Debug ST Program",
            "args": ["--cyclic"]
          }
        ],
        "configurationSnippets": [
          {
            "label": "STruC++: Debug ST Program",
            "description": "Debug a Structured Text program with source-level debugging",
            "body": {
              "type": "strucpp",
              "request": "launch",
              "name": "Debug ST Program",
              "args": ["--cyclic"]
            }
          }
        ]
      }
    ],
    "taskDefinitions": [
      {
        "type": "strucpp",
        "required": ["command"],
        "properties": {
          "command": {
            "type": "string",
            "enum": ["compile", "build", "buildAndRun"],
            "description": "The STruC++ command to run"
          },
          "file": {
            "type": "string",
            "description": "Source file to compile (defaults to active editor)"
          },
          "output": {
            "type": "string",
            "description": "Output directory (overrides strucpp.outputDirectory)"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "strucpp-gpp",
        "owner": "strucpp",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+):(\\d+):(\\d+):\\s+(error|warning|note):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    ]
  },
  "scripts": {
    "build": "tsc -b",
    "watch": "tsc -b --watch",
    "bundle": "tsc -b && node esbuild.mjs",
    "vscode:prepublish": "node esbuild.mjs --production",
    "package": "vsce package",
    "lint": "eslint client/src server/src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "strucpp": "file:..",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.82.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
