{
  "name": "strucpp",
  "version": "0.1.0-dev",
  "description": "IEC 61131-3 Structured Text to C++ Compiler",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:stdlib": "node scripts/generate-stdlib.mjs",
    "build:bundle": "npm run build && esbuild dist/cli.js --bundle --platform=node --target=node18 --outfile=dist/strucpp-bundle.cjs --format=cjs",
    "build:pkg": "npm run build:bundle && pkg dist/strucpp-bundle.cjs --targets node18-linux-x64,node18-win-x64,node18-macos-x64 --out-path dist/bin --compress GZip",
    "build:pkg:linux": "npm run build:bundle && pkg dist/strucpp-bundle.cjs --targets node18-linux-x64 --output dist/bin/strucpp-linux --compress GZip",
    "build:pkg:win": "npm run build:bundle && pkg dist/strucpp-bundle.cjs --targets node18-win-x64 --output dist/bin/strucpp-win.exe --compress GZip",
    "build:pkg:macos": "npm run build:bundle && pkg dist/strucpp-bundle.cjs --targets node18-macos-x64 --output dist/bin/strucpp-macos --compress GZip",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "bin": {
    "strucpp": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "runtime/",
    "libs/"
  ],
  "keywords": [
    "iec61131-3",
    "plc",
    "structured-text",
    "compiler",
    "code-generator",
    "openplc"
  ],
  "author": "Autonomy Logic / OpenPLC Project <thiago.alves@autonomylogic.com>",
  "license": "LGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Autonomy-Logic/STruCpp.git"
  },
  "bugs": {
    "url": "https://github.com/Autonomy-Logic/STruCpp/issues"
  },
  "homepage": "https://github.com/Autonomy-Logic/STruCpp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chevrotain": "^11.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": "prettier --write",
    "src/**/*.{json,md}": "prettier --write"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "esbuild": "^0.27.0",
    "eslint": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "pkg": "^5.8.1",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
