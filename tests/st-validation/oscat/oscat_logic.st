(* OSCAT Logic Function Blocks — Flip-flops and sequential logic *)

FUNCTION_BLOCK FF_JKE
VAR_INPUT
	SET : BOOL;
	J : BOOL;
	CLK : BOOL;
	K : BOOL;
	RST : BOOL;
END_VAR
VAR_OUTPUT
	Q : BOOL;
END_VAR
VAR
	EDGE : BOOL;
END_VAR
IF RST OR SET THEN
	Q := NOT RST;
ELSIF CLK AND NOT EDGE THEN
	IF J XOR K THEN
		Q := J;
	ELSE
		Q := K XOR Q;
	END_IF;
END_IF;
EDGE := CLK;
END_FUNCTION_BLOCK

FUNCTION FLOOR2 : DINT
VAR_INPUT
	X : REAL;
END_VAR
FLOOR2 := REAL_TO_DINT(X);
IF DINT_TO_REAL(FLOOR2) > X THEN
	FLOOR2 := FLOOR2 - 1;
END_IF;
END_FUNCTION

FUNCTION MODR : REAL
VAR_INPUT
	IN : REAL;
	DIVI : REAL;
END_VAR
IF DIVI = 0.0 THEN
	MODR := 0.0;
ELSE
	MODR := IN - DINT_TO_REAL(FLOOR2(IN / DIVI)) * DIVI;
END_IF;
END_FUNCTION
