(* OSCAT String Functions — String manipulation using standard IEC string ops *)

FUNCTION TRIM : STRING(254)
VAR_INPUT
	STR : STRING(254);
END_VAR
VAR
	POS : INT;
END_VAR
TRIM := STR;
REPEAT
	POS := FIND(TRIM, ' ');
	IF POS > 0 THEN TRIM := REPLACE(TRIM, '', 1, POS); END_IF;
UNTIL POS = 0 END_REPEAT;
END_FUNCTION

FUNCTION TRIM1 : STRING(254)
VAR_INPUT
	STR : STRING(254);
END_VAR
VAR
	POS : INT;
END_VAR
TRIM1 := STR;
REPEAT
	POS := FIND(TRIM1, '  ');
	IF POS > 0 THEN TRIM1 := REPLACE(TRIM1, ' ', 2, POS); END_IF;
UNTIL POS = 0 END_REPEAT;
IF LEFT(TRIM1, 1) = ' ' THEN TRIM1 := DELETE(TRIM1, 1, 1); END_IF;
IF RIGHT(TRIM1, 1) = ' ' THEN TRIM1 := DELETE(TRIM1, 1, LEN(TRIM1)); END_IF;
END_FUNCTION

FUNCTION FINDB : INT
VAR_INPUT
	STR1 : STRING(254);
	STR2 : STRING(254);
END_VAR
VAR
	POS : INT;
	LENGTH : INT;
END_VAR
LENGTH := LEN(STR2);
FOR POS := LEN(STR1) - LENGTH + 1 TO 1 BY -1 DO
	IF MID(STR1, LENGTH, POS) = STR2 THEN
		FINDB := POS;
		RETURN;
	END_IF;
END_FOR;
FINDB := 0;
END_FUNCTION

FUNCTION REPLACE_CHARS : STRING(254)
VAR_INPUT
	STR : STRING(254);
	SRC : STRING(254);
	REP : STRING(254);
END_VAR
VAR
	A : INT;
	B : INT;
	C : STRING(1);
	STP : INT;
END_VAR
REPLACE_CHARS := STR;
A := LEN(SRC);
B := LEN(REP);
IF A < B THEN
	REP := LEFT(REP, A);
ELSIF B < A THEN
	SRC := LEFT(SRC, B);
END_IF;
STP := LEN(STR);
FOR A := 1 TO STP DO
	C := MID(REPLACE_CHARS, 1, A);
	B := FIND(SRC, C);
	IF B > 0 THEN
		REPLACE_CHARS := REPLACE(REPLACE_CHARS, MID(REP, 1, B), 1, A);
	END_IF;
END_FOR;
END_FUNCTION
