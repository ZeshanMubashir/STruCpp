(* OSCAT Control Function Blocks — Stateful control elements *)

FUNCTION_BLOCK TOGGLE
VAR_INPUT
	CLK : BOOL;
	RST : BOOL;
END_VAR
VAR_OUTPUT
	Q : BOOL;
END_VAR
VAR
	EDGE : BOOL;
END_VAR
IF RST THEN
	Q := FALSE;
ELSIF CLK AND NOT EDGE THEN
	Q := NOT Q;
END_IF;
EDGE := CLK;
END_FUNCTION_BLOCK

FUNCTION_BLOCK HYST_1
VAR_INPUT
	IN : REAL;
	HIGH : REAL;
	LOW : REAL;
END_VAR
VAR_OUTPUT
	Q : BOOL;
	WIN : BOOL;
END_VAR
IF IN < LOW THEN
	Q := FALSE;
	WIN := FALSE;
ELSIF IN > HIGH THEN
	Q := TRUE;
	WIN := FALSE;
ELSE
	WIN := TRUE;
END_IF;
END_FUNCTION_BLOCK

FUNCTION_BLOCK MANUAL_1
VAR_INPUT
	IN : BOOL;
	MAN : BOOL;
	M_I : BOOL;
	SET : BOOL;
	RST : BOOL;
END_VAR
VAR_OUTPUT
	Q : BOOL;
	STATUS : BYTE;
END_VAR
VAR
	S_EDGE : BOOL;
	R_EDGE : BOOL;
	MEDGE : BOOL;
END_VAR
IF NOT MAN THEN
	Q := IN;
	STATUS := 100;
	MEDGE := FALSE;
ELSIF NOT S_EDGE AND SET THEN
	Q := TRUE;
	MEDGE := TRUE;
	STATUS := 101;
ELSIF NOT R_EDGE AND RST THEN
	Q := FALSE;
	MEDGE := TRUE;
	STATUS := 102;
ELSIF NOT MEDGE THEN
	Q := M_I;
	STATUS := 103;
END_IF;
S_EDGE := SET;
R_EDGE := RST;
END_FUNCTION_BLOCK
