(* OSCAT Hyperbolic Math Functions — Pure math, no external dependencies *)

FUNCTION ACOSH : REAL
VAR_INPUT
	X : REAL;
END_VAR
ACOSH := LN(SQRT(X * X - 1.0) + X);
END_FUNCTION

FUNCTION ASINH : REAL
VAR_INPUT
	X : REAL;
END_VAR
ASINH := LN(SQRT(X * X + 1.0) + X);
END_FUNCTION

FUNCTION ATANH : REAL
VAR_INPUT
	X : REAL;
END_VAR
ATANH := LN((1.0 + X) / (1.0 - X)) * 0.5;
END_FUNCTION

FUNCTION ACOTH : REAL
VAR_INPUT
	X : REAL;
END_VAR
ACOTH := LN((X + 1.0) / (X - 1.0)) * 0.5;
END_FUNCTION

FUNCTION SIGN_R : BOOL
VAR_INPUT
	IN : REAL;
END_VAR
SIGN_R := IN < 0.0;
END_FUNCTION
